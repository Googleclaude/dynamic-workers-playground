{
  "name": "dynamic-workers-playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "build": "npm run check:lgpd && vite build && wrangler deploy",
    "deploy": "npm run check:lgpd && vite build && wrangler deploy",
    "test": "vitest run",
    "types": "wrangler types env.d.ts --include-runtime false",
    "check:lgpd": "node scripts/check-lgpd-constants.mjs"
  },
  "dependencies": {
    "@cloudflare/kumo": "^1.15.0",
    "@cloudflare/worker-bundler": "^0.0.4",
    "@phosphor-icons/react": "^2.1.10",
    "@typescript/vfs": "^1.6.0",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.0",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vitest": "^3.0.0",
    "wrangler": "^4.76.0"
  }
}
