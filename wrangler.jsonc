{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dynamic-workers-playground",
  "main": "src/server.ts",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "worker_loaders": [{ "binding": "LOADER" }],
  "durable_objects": {
    "bindings": [
      { "name": "LogSession", "class_name": "LogSession" },
      { "name": "LgpdRateLimit", "class_name": "LgpdRateLimit" }
    ]
  },
  // LGPD persistence is optional. To enable rights-request / consent-audit
  // storage, create a KV namespace and add it here:
  //   npx wrangler kv namespace create lgpd_storage
  //   "kv_namespaces": [{ "binding": "LGPD_KV", "id": "<id from above>" }]
  //   npm run types   # regenerates env.d.ts with the binding
  "migrations": [
    { "tag": "v1", "new_classes": ["LogSession"] },
    { "tag": "v2", "new_classes": ["LgpdRateLimit"] }
  ],
  "observability": {
    "enabled": true
  }
}
